{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "1.0.0",
  "description": "Chat with Claude and ChatGPT from the sidebar using your existing sessions",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "activeTab",
    "cookies"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "AI Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "unblock_frames",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+L"
      },
      "description": "Open AI Sidebar"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
